<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FD">

    <!-- Header Section -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="#2C3E50"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDashboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="Admin Dashboard"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtAdminInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Chào mừng trở lại, Admin"
        android:textColor="#B0BEC5"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@+id/tvDashboardTitle"
        app:layout_constraintTop_toBottomOf="@+id/tvDashboardTitle" />

    <ImageButton
        android:id="@+id/btnLogoutAdmin"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_lock_power_off"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="@+id/txtAdminInfo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvDashboardTitle" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavContainer"
        app:layout_constraintTop_toBottomOf="@+id/txtAdminInfo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="140dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#3F51B5"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvSummaryTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thống kê hệ\nthống hôm nay"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Hoạt động ổn định với 98% hiệu suất."
                        android:textColor="#D1D9FF"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toStartOf="@+id/ivChart"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tvSummaryTitle" />

                    <ImageView
                        android:id="@+id/ivChart"
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:alpha="0.2"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:tint="#FFFFFF" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Grid Menu -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:columnCount="2">

                <!-- Mã giảm giá -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnManagePromo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <View
                            android:id="@+id/vIconPromo"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="#EDE7F6"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_gallery"
                            app:layout_constraintBottom_toBottomOf="@+id/vIconPromo"
                            app:layout_constraintEnd_toEndOf="@+id/vIconPromo"
                            app:layout_constraintStart_toStartOf="@+id/vIconPromo"
                            app:layout_constraintTop_toTopOf="@+id/vIconPromo"
                            app:tint="#673AB7" />

                        <TextView
                            android:id="@+id/tvPromoTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Mã giảm giá"
                            android:textColor="#333333"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/vIconPromo" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Quản lý các chương trình ưu đãi"
                            android:textColor="#757575"
                            android:textSize="10sp"
                            app:layout_constraintTop_toBottomOf="@+id/tvPromoTitle" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginTop="16dp"
                            android:background="#F5F5F5"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_media_next"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tvPromoTitle" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Lịch sử sửa xe -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnManageRepairHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <View
                            android:id="@+id/vIconRepair"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="#FFF3E0"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_preferences"
                            app:layout_constraintBottom_toBottomOf="@+id/vIconRepair"
                            app:layout_constraintEnd_toEndOf="@+id/vIconRepair"
                            app:layout_constraintStart_toStartOf="@+id/vIconRepair"
                            app:layout_constraintTop_toTopOf="@+id/vIconRepair"
                            app:tint="#FF9800" />

                        <TextView
                            android:id="@+id/tvRepairTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Lịch sử sửa xe"
                            android:textColor="#333333"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/vIconRepair" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Theo dõi quá trình bảo trì thiết bị"
                            android:textColor="#757575"
                            android:textSize="10sp"
                            app:layout_constraintTop_toBottomOf="@+id/tvRepairTitle" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginTop="16dp"
                            android:background="#F5F5F5"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_media_next"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tvRepairTitle" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Quản lý Admin -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnAdminManagement"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <View
                            android:id="@+id/vIconAdmin"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="#E8EAF6"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:layout_constraintBottom_toBottomOf="@+id/vIconAdmin"
                            app:layout_constraintEnd_toEndOf="@+id/vIconAdmin"
                            app:layout_constraintStart_toStartOf="@+id/vIconAdmin"
                            app:layout_constraintTop_toTopOf="@+id/vIconAdmin"
                            app:tint="#3F51B5" />

                        <TextView
                            android:id="@+id/tvAdminTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Quản lý Admin"
                            android:textColor="#333333"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/vIconAdmin" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Phân quyền và tài khoản hệ thống"
                            android:textColor="#757575"
                            android:textSize="10sp"
                            app:layout_constraintTop_toBottomOf="@+id/tvAdminTitle" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginTop="16dp"
                            android:background="#F5F5F5"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_media_next"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tvAdminTitle" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Lịch sử đặt lịch -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnTransactionHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <View
                            android:id="@+id/vIconHistory"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="#FFEBEE"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:layout_constraintBottom_toBottomOf="@+id/vIconHistory"
                            app:layout_constraintEnd_toEndOf="@+id/vIconHistory"
                            app:layout_constraintStart_toStartOf="@+id/vIconHistory"
                            app:layout_constraintTop_toTopOf="@+id/vIconHistory"
                            app:tint="#F44336" />

                        <TextView
                            android:id="@+id/tvHistoryTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Lịch sử đặt lịch"
                            android:textColor="#333333"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/vIconHistory" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Xem danh sách các lịch hẹn sửa xe"
                            android:textColor="#757575"
                            android:textSize="10sp"
                            app:layout_constraintTop_toBottomOf="@+id/tvHistoryTitle" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginTop="16dp"
                            android:background="#F5F5F5"
                            android:padding="6dp"
                            android:src="@android:drawable/ic_media_next"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tvHistoryTitle" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- System Status Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TRẠNG THÁI HỆ THỐNG"
                        android:textColor="#37474F"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="30dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:background="#3F51B5" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Người dùng mới"
                            android:textColor="#546E7A" />
                        <TextView
                            android:id="@+id/tvStatUser"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="+0"
                            android:textColor="#1A237E"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Doanh thu hôm nay"
                            android:textColor="#546E7A" />
                        <TextView
                            android:id="@+id/tvStatRevenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0 VNĐ"
                            android:textColor="#1A237E"
                            android:textStyle="bold" />
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Custom -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navPromo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="#3F51B5" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giảm giá"
                android:textColor="#3F51B5"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRepair"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_preferences"
                app:tint="#B0BEC5" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sửa chữa"
                android:textColor="#B0BEC5"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAdmin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#B0BEC5" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin"
                android:textColor="#B0BEC5"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#B0BEC5" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lịch sử"
                android:textColor="#B0BEC5"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
